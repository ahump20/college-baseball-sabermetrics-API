#!/usr/bin/env bash

# Blaze Sports Intel - Commit message secret detection hook
# Prevent secrets from being leaked via commit metadata.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

commit_msg_file="${1:-}"
if [ -z "$commit_msg_file" ] || [ ! -f "$commit_msg_file" ]; then
  echo -e "${RED}✗ commit-msg hook requires a valid commit message file${NC}"
  exit 1
fi

echo -e "${BLUE}🔐 Scanning commit message for leaked secrets...${NC}"

# Patterns are intentionally broad because commit text should never include live credentials.
declare -A patterns=(
  ["OpenAI key"]='sk-(proj-|svcacct-|live-|test-)?[A-Za-z0-9_-]{20,}'
  ["Anthropic key"]='sk-ant-[A-Za-z0-9_-]{20,}'
  ["Stripe key"]='(sk|pk)_(live|test)_[A-Za-z0-9]{16,}'
  ["GitHub PAT"]='github_pat_[A-Za-z0-9_]{20,}|gh[pousr]_[A-Za-z0-9]{20,}'
  ["Cloudflare token"]='CLOUDFLARE_[A-Z0-9_]*TOKEN[[:space:]]*=[[:space:]]*[^[:space:]]{16,}'
  ["Generic secret assignment"]='(^|[[:space:]])[A-Z][A-Z0-9_]*(SECRET|TOKEN|API_KEY|ACCESS_KEY|PRIVATE_KEY|CLIENT_SECRET)[[:space:]]*=[[:space:]]*[^[:space:]]{12,}'
)

violations=0
match_file="$(mktemp -t commit_msg_secret_match.XXXXXX)"
trap 'rm -f "$match_file"' EXIT INT TERM HUP
for name in "${!patterns[@]}"; do
  pattern="${patterns[$name]}"
  if grep -nE "$pattern" "$commit_msg_file" >"$match_file" 2>/dev/null; then
    if [ "$violations" -eq 0 ]; then
      echo -e "${RED}✗ Potential secret detected in commit message:${NC}"
    fi
    echo -e "${YELLOW}  • ${name}${NC}"
    read -r first_match_line < "$match_file" || first_match_line=""
    line_number="${first_match_line%%:*}"
    if [ -n "$line_number" ]; then
      echo "      (first match on line ${line_number}, content redacted)"
    else
      echo "      (match found, line information unavailable; content redacted)"
    fi
    violations=$((violations + 1))
  fi
done

if [ "$violations" -gt 0 ]; then
  echo ""
  echo -e "${RED}Commit blocked to prevent credential leakage in git history.${NC}"
  echo -e "${YELLOW}Remove secrets from the commit message and retry.${NC}"
  exit 1
fi

echo -e "${GREEN}✓ Commit message scan passed${NC}"
